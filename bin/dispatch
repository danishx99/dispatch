#!/usr/bin/env node
'use strict';

const fs = require('fs');
const path = require('path');
const os = require('os');
const { spawnSync } = require('child_process');

const HOME = os.homedir();
const CWD = process.cwd();
const TOOLS = ['claude', 'codex'];

const HELP_TOP = `dispatch — move context between Claude Code and Codex CLI

usage: dispatch <command> [options]

commands:
  fork <claude|codex>      Continue the current session in another tool
  handoff <claude|codex>   Open a fresh session in another tool with a brief
  init                     Install the handoff skill into your skills dir

run \`dispatch <command> --help\` for command-specific options.

requires tmux, plus claude and/or codex on PATH.`;

const HELP_FORK = `usage: dispatch fork <claude|codex> [options]

Continue the current session in another tool. Same-tool fork delegates to
the tool's native fork machinery; cross-tool fork snapshots the source
session and starts the target with a pointer prompt.

options:
  --new-pane             Open in a new tmux pane to the right (default)
  --replace              Replace the current tmux pane instead
  --source <claude|codex>  Restrict source-session resolution to one tool
  --from <id>            Pin to a specific session UUID (requires --source)
  -h, --help             Show this help

examples:
  dispatch fork codex                  # claude → codex via MRM source
  dispatch fork claude --replace       # claude → claude, replace this pane
  dispatch fork claude --source codex  # codex → claude (forced source)`;

const HELP_HANDOFF = `usage: dispatch handoff <claude|codex> "<brief>"|- [options]

Open the target tool in a fresh session with a brief as the first prompt.
Pass \`-\` as the brief to read from stdin (heredoc-friendly). Usually
invoked by an LLM via the installed handoff skill.

options:
  --new-pane             Open in a new tmux pane to the right (default)
  --replace              Replace the current tmux pane instead
  -h, --help             Show this help

examples:
  dispatch handoff codex "fix the failing test in foo.spec.ts"
  dispatch handoff claude - <<'BRIEF'
  ## Goal
  ...
  BRIEF`;

const HELP_INIT = `usage: dispatch init [options]

Interactively install the handoff skill into your skill directories.
Detects ~/.claude/skills/ and ~/.agents/skills/ and offers each as a
checkbox; existing dirs are pre-ticked. Press 1/2 to toggle, enter to
install, q to cancel.

Non-interactive (no TTY): installs to all detected skill directories,
errors if none exist.

options:
  -h, --help             Show this help`;

function hasHelp(args) {
  return args.includes('-h') || args.includes('--help');
}

function die(msg, code = 1) {
  process.stderr.write(msg.endsWith('\n') ? msg : msg + '\n');
  process.exit(code);
}

function requireTmux() {
  if (!process.env.TMUX) die('dispatch requires an active tmux session.');
}

function shellQuote(s) {
  return "'" + String(s).replace(/'/g, "'\\''") + "'";
}

function encodeCwdForClaude(cwd) {
  return cwd.replace(/\//g, '-');
}

// Parse target + flags. Returns {target, flags, positional}.
function parseArgs(args, allowed) {
  const flags = {};
  const positional = [];
  for (let i = 0; i < args.length; i++) {
    const a = args[i];
    if (a === '--new-pane' || a === '--replace') {
      flags.pane = a === '--replace' ? 'replace' : 'new-pane';
    } else if (a === '--source') {
      flags.source = args[++i];
    } else if (a === '--from') {
      flags.from = args[++i];
    } else if (a.startsWith('--')) {
      die(`unknown flag: ${a}`);
    } else {
      positional.push(a);
    }
  }
  if (!flags.pane) flags.pane = 'new-pane';
  return { flags, positional };
}

// --- source resolution ---

function listClaudeSessions(cwd) {
  const dir = path.join(HOME, '.claude', 'projects', encodeCwdForClaude(cwd));
  if (!fs.existsSync(dir)) return [];
  return fs.readdirSync(dir)
    .filter(f => f.endsWith('.jsonl'))
    .map(f => {
      const p = path.join(dir, f);
      const stat = fs.statSync(p);
      return {
        tool: 'claude',
        id: f.replace(/\.jsonl$/, ''),
        path: p,
        mtime: stat.mtimeMs,
      };
    });
}

function readFirstLine(p) {
  const fd = fs.openSync(p, 'r');
  try {
    const buf = Buffer.alloc(65536);
    let acc = '';
    while (true) {
      const n = fs.readSync(fd, buf, 0, buf.length, null);
      if (n === 0) return acc;
      acc += buf.slice(0, n).toString('utf8');
      const i = acc.indexOf('\n');
      if (i >= 0) return acc.slice(0, i);
    }
  } finally {
    fs.closeSync(fd);
  }
}

function listCodexSessions(cwd) {
  const today = new Date();
  const yyyy = String(today.getUTCFullYear());
  const mm = String(today.getUTCMonth() + 1).padStart(2, '0');
  const dd = String(today.getUTCDate()).padStart(2, '0');
  const dir = path.join(HOME, '.codex', 'sessions', yyyy, mm, dd);
  if (!fs.existsSync(dir)) return [];
  const out = [];
  for (const f of fs.readdirSync(dir)) {
    if (!f.startsWith('rollout-') || !f.endsWith('.jsonl')) continue;
    const p = path.join(dir, f);
    let firstLine;
    try { firstLine = readFirstLine(p); } catch { continue; }
    let meta;
    try { meta = JSON.parse(firstLine); } catch { continue; }
    if (!meta || meta.type !== 'session_meta' || !meta.payload) continue;
    if (meta.payload.cwd !== cwd) continue;
    const stat = fs.statSync(p);
    out.push({
      tool: 'codex',
      id: meta.payload.id,
      path: p,
      mtime: stat.mtimeMs,
    });
  }
  return out;
}

function resolveSource(flags) {
  // Explicit override path
  if (flags.from) {
    const tool = flags.source;
    if (!tool) die('--from requires --source <claude|codex>');
    if (!TOOLS.includes(tool)) die(`--source must be claude or codex`);
    const candidates = tool === 'claude' ? listClaudeSessions(CWD) : listCodexSessions(CWD);
    const hit = candidates.find(c => c.id === flags.from);
    if (!hit) die(`no ${tool} session with id ${flags.from} in ${CWD}`);
    return hit;
  }

  let candidates = [];
  if (!flags.source || flags.source === 'claude') candidates = candidates.concat(listClaudeSessions(CWD));
  if (!flags.source || flags.source === 'codex') candidates = candidates.concat(listCodexSessions(CWD));

  if (candidates.length === 0) {
    die(
      `no sessions found for cwd ${CWD}\n` +
      `  scanned: ~/.claude/projects/${encodeCwdForClaude(CWD)}/\n` +
      `           ~/.codex/sessions/<today>/ (filtered by cwd)`
    );
  }
  candidates.sort((a, b) => b.mtime - a.mtime);
  return candidates[0];
}

// --- pane placement ---

function placeInPane(launchCmd, mode) {
  const tmuxArgs = mode === 'replace'
    ? ['respawn-pane', '-k', launchCmd]
    : ['split-window', '-h', launchCmd];
  const r = spawnSync('tmux', tmuxArgs, { stdio: 'inherit' });
  if (r.status !== 0) die(`tmux ${tmuxArgs[0]} failed`);
}

// --- commands ---

function cmdFork(args) {
  if (hasHelp(args)) { console.log(HELP_FORK); return; }
  const { flags, positional } = parseArgs(args);
  const target = positional[0];
  if (!TOOLS.includes(target)) die(HELP_FORK);
  if (flags.source && !TOOLS.includes(flags.source)) die('--source must be claude or codex');
  requireTmux();

  const source = resolveSource(flags);

  let launchCmd;
  if (source.tool === target) {
    // Same-tool fork: delegate to native fork machinery.
    if (target === 'claude') {
      launchCmd = `claude --resume ${source.id} --fork-session`;
    } else {
      launchCmd = `codex fork ${source.id}`;
    }
  } else {
    // Cross-tool fork: snapshot + pointer prompt.
    const snapDir = path.join(HOME, '.dispatch', 'snapshots');
    fs.mkdirSync(snapDir, { recursive: true });
    const ts = Math.floor(Date.now() / 1000);
    const snapPath = path.join(snapDir, `${ts}-${source.id}.jsonl`);
    fs.copyFileSync(source.path, snapPath);
    const prompt =
      `This session is a fork of ${source.tool}. The full prior session\n` +
      `is at ${snapPath}. Read it for context as needed.`;
    launchCmd = `${target} ${shellQuote(prompt)}`;
  }

  placeInPane(launchCmd, flags.pane);
}

function cmdHandoff(args) {
  if (hasHelp(args)) { console.log(HELP_HANDOFF); return; }
  const { flags, positional } = parseArgs(args);
  const target = positional[0];
  if (!TOOLS.includes(target)) die(HELP_HANDOFF);
  let brief = positional[1];
  if (brief === undefined) die('handoff requires a brief (positional string or `-` for stdin)');
  if (brief === '-') {
    brief = fs.readFileSync(0, 'utf8');
  }
  if (!brief.trim()) die('brief is empty');
  requireTmux();

  const launchCmd = `${target} ${shellQuote(brief)}`;
  placeInPane(launchCmd, flags.pane);
}

function installSkillTo(dirs) {
  const scriptPath = fs.realpathSync(__filename);
  const src = path.resolve(path.dirname(scriptPath), '..', 'skills', 'handoff', 'SKILL.md');
  if (!fs.existsSync(src)) die(`source skill not found at ${src}`);
  // Dedupe by real path so a symlinked dir (e.g. ~/.claude/skills → ~/.agents/skills) isn't written twice.
  const seen = new Set();
  for (const dir of dirs) {
    fs.mkdirSync(dir, { recursive: true });
    const real = fs.realpathSync(dir);
    if (seen.has(real)) continue;
    seen.add(real);
    const dest = path.join(dir, 'handoff');
    fs.mkdirSync(dest, { recursive: true });
    fs.copyFileSync(src, path.join(dest, 'SKILL.md'));
    console.log(`Installed → ${path.join(dest, 'SKILL.md')}`);
  }
}

function cmdInit(args = []) {
  if (hasHelp(args)) { console.log(HELP_INIT); return; }
  const candidates = [
    { label: '~/.claude/skills/', dir: path.join(HOME, '.claude', 'skills') },
    { label: '~/.agents/skills/', dir: path.join(HOME, '.agents', 'skills') },
  ];
  const ticked = candidates.map(c => fs.existsSync(c.dir));

  // Non-TTY: install to all existing dirs, or fail loudly.
  if (!process.stdin.isTTY) {
    const chosen = candidates.filter((_, i) => ticked[i]).map(c => c.dir);
    if (chosen.length === 0) {
      die('no skill directories exist (~/.claude/skills/ or ~/.agents/skills/) and stdin is not a TTY. Run interactively or create one of these dirs first.');
    }
    installSkillTo(chosen);
    return;
  }

  // Interactive raw-mode TTY render. Single keypress flips a row in place.
  let renderedLines = 0;
  function render() {
    if (renderedLines > 0) {
      process.stdout.write(`\x1b[${renderedLines}A\x1b[0J`);
    }
    const lines = [];
    lines.push('Install handoff skill to:');
    candidates.forEach((c, i) => {
      const mark = ticked[i] ? 'x' : ' ';
      const status = fs.existsSync(c.dir) ? '(exists)' : '(will create)';
      lines.push(`  [${mark}] ${i + 1}) ${c.label.padEnd(22)} ${status}`);
    });
    lines.push('');
    lines.push(`Press 1-${candidates.length} to toggle, enter to install, q to cancel`);
    const out = lines.join('\n') + '\n';
    process.stdout.write(out);
    renderedLines = lines.length;
  }

  function cleanup() {
    if (process.stdin.isTTY) process.stdin.setRawMode(false);
    process.stdin.pause();
  }

  process.stdin.setRawMode(true);
  process.stdin.resume();
  process.stdin.setEncoding('utf8');
  render();

  process.stdin.on('data', (key) => {
    // Cancel: q, Q, Esc, Ctrl-C
    if (key === 'q' || key === 'Q' || key === '\u001b' || key === '\u0003') {
      cleanup();
      process.stdout.write('cancelled.\n');
      process.exit(0);
    }
    // Accept: Enter
    if (key === '\r' || key === '\n') {
      if (!ticked.some(Boolean)) {
        process.stdout.write('\x07'); // bell — nothing selected
        return;
      }
      cleanup();
      const chosen = candidates.filter((_, i) => ticked[i]).map(c => c.dir);
      installSkillTo(chosen);
      process.exit(0);
    }
    // Toggle: number key
    const n = parseInt(key, 10);
    if (Number.isInteger(n) && n >= 1 && n <= candidates.length) {
      ticked[n - 1] = !ticked[n - 1];
      render();
    }
  });
}

// --- entrypoint ---

const [,, sub, ...rest] = process.argv;
switch (sub) {
  case 'fork': cmdFork(rest); break;
  case 'handoff': cmdHandoff(rest); break;
  case 'init': cmdInit(rest); break;
  case undefined:
  case '-h':
  case '--help':
    console.log(HELP_TOP);
    break;
  case '-v':
  case '--version': {
    const pkg = require(path.resolve(path.dirname(fs.realpathSync(__filename)), '..', 'package.json'));
    console.log(pkg.version);
    break;
  }
  default:
    die(`unknown command: ${sub}\n\n${HELP_TOP}`);
}
